<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="35.0" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125667.controller.MainMenuController">
    
    <Label text="JavArena Dungeons" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="48.0" />
        </font>
    </Label>
    
    <Label text="Forgia il tuo eroe, entra nell'arena e scrivi la tua leggenda." textFill="#7f8c8d">
        <font>
            <Font size="18.0" />
        </font>
    </Label>

    <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 30 0 0 0;">
        <Button text="Nuova Partita" onAction="#onNewGameClick" prefHeight="50.0" prefWidth="250.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;" />
        <Button text="Carica Partita" onAction="#onLoadGameClick" prefHeight="50.0" prefWidth="250.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;" />
    </VBox>

    <Label fx:id="statusLabel" textFill="RED" style="-fx-padding: 20 0 0 0;">
        <font><Font size="14.0" /></font>
    </Label>
</VBox>