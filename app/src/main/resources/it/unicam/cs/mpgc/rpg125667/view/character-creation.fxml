<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125667.controller.CharacterCreationController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Crea il tuo Eroe">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label text="Come ti chiami, viandante?" />
    <TextField fx:id="nameField" maxWidth="250.0" promptText="Inserisci il tuo nome..." />

    <HBox alignment="CENTER" spacing="40.0">
        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Attacco Base" textFill="DARKRED">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Label fx:id="attackLabel" text="?">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>
        </VBox>
        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Difesa Base" textFill="DARKBLUE">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Label fx:id="defenseLabel" text="?">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>
        </VBox>
    </HBox>

    <Button text="Rilancia Statistiche" onAction="#onRollStatsClick" />

    <Label fx:id="errorLabel" textFill="RED" />

    <Button text="Inizia l'Avventura" onAction="#onCreateHeroClick" prefHeight="40.0" />
    <Button text="Torna al Menu" onAction="#onBackToMenuClick" />
</VBox>