<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125667.controller.ArenaController">
    
    <padding>
        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER" spacing="40.0" VBox.vgrow="NEVER">
        
        <VBox alignment="CENTER_LEFT" spacing="8.0" prefWidth="300.0" style="-fx-background-color: #e8f6e9; -fx-padding: 15; -fx-border-color: #a5d6a7; -fx-border-radius: 5; -fx-background-radius: 5;">
            <Label fx:id="playerNameLabel" text="Eroe" textFill="#2e7d32"><font><Font name="System Bold" size="20.0" /></font></Label>
            <Label fx:id="playerHpLabel" text="HP: ?" textFill="#1b5e20"><font><Font name="System Bold" size="18.0" /></font></Label>
            <Label fx:id="playerStatsLabel" text="Att: ? | Dif: ?" textFill="#388e3c"><font><Font size="14.0" /></font></Label>
        </VBox>

        <Label text="VS" minWidth="-Infinity" textFill="#c0392b">
            <font><Font name="System Bold Italic" size="28.0" /></font>
        </Label>

        <VBox alignment="CENTER_RIGHT" spacing="8.0" prefWidth="300.0" style="-fx-background-color: #fdebd0; -fx-padding: 15; -fx-border-color: #e74c3c; -fx-border-radius: 5; -fx-background-radius: 5;">
            <Label fx:id="monsterNameLabel" text="Mostro" textFill="#c0392b"><font><Font name="System Bold" size="20.0" /></font></Label>
            <Label fx:id="monsterHpLabel" text="HP: ?" textFill="#922b21"><font><Font name="System Bold" size="18.0" /></font></Label>
            <Label fx:id="monsterStatsLabel" text="Att: ? | Dif: ?" textFill="#e74c3c"><font><Font size="14.0" /></font></Label>
        </VBox>
    </HBox>

    <TextArea fx:id="battleLog" editable="false" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 16px; -fx-background-color: #ffffff; -fx-border-color: #bdc3c7;" />

    <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="NEVER">
        <Button fx:id="attackButton" text="Attacca" onAction="#onAttackClick" prefHeight="50.0" minWidth="160.0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-base: #e74c3c;" />
        <Button fx:id="healButton" text="Cura" onAction="#onHealClick" prefHeight="50.0" minWidth="160.0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-base: #2ecc71;" />
        <Button fx:id="saveButton" text="Salva Partita" onAction="#onManualSaveClick" prefHeight="50.0" minWidth="180.0" style="-fx-font-size: 16px;" />
        <Button fx:id="backButton" text="Torna alla Home" onAction="#onBackToMenuClick" disable="true" prefHeight="50.0" minWidth="180.0" style="-fx-font-size: 16px;" />
    </HBox>
</VBox>