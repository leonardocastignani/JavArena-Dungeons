<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125667.controller.ArenaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER" spacing="100.0">
        <VBox alignment="CENTER" spacing="5.0">
            <Label fx:id="playerNameLabel" text="Giocatore">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Label fx:id="playerHpLabel" text="HP: ?/?" textFill="GREEN">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Label fx:id="playerStatsLabel" text="Att: ? | Dif: ?" textFill="DARKGRAY">
                <font><Font size="12.0" /></font>
            </Label>
        </VBox>

        <Label text="VS">
            <font><Font name="System Bold Italic" size="24.0" /></font>
        </Label>

        <VBox alignment="CENTER" spacing="5.0">
            <Label fx:id="monsterNameLabel" text="Mostro">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Label fx:id="monsterHpLabel" text="HP: ?/?" textFill="RED">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Label fx:id="monsterStatsLabel" text="Att: ? | Dif: ?" textFill="DARKGRAY">
                <font><Font size="12.0" /></font>
            </Label>
        </VBox>
    </HBox>

    <TextArea fx:id="battleLog" editable="false" prefHeight="150.0" prefWidth="560.0" wrapText="true" />

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="attackButton" text="Attacca" onAction="#onAttackClick" prefWidth="100.0" prefHeight="40.0" />
        
        <Button fx:id="healButton" text="Curati" onAction="#onHealClick" prefWidth="110.0" prefHeight="40.0" />
        
        <Button fx:id="backButton" text="Torna al Menu" onAction="#onBackToMenuClick" prefWidth="130.0" prefHeight="40.0" disable="true" />
    </HBox>
</VBox>