<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox id="game-over-root" alignment="CENTER" spacing="30.0" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125667.controller.GameOverController">
    
    <Label text="SEI MORTO" textFill="RED">
        <font>
            <Font name="System Bold" size="58.0" />
        </font>
    </Label>
    
    <Label text="La tua avventura finisce qui. Il tuo eroe è stato cancellato dagli annali." textFill="WHITE">
        <font>
            <Font size="16.0" />
        </font>
    </Label>
    
    <Button fx:id="menuButton" text="Torna al Menu" onAction="#onBackToMenuClick" prefHeight="40.0" prefWidth="150.0" />
</VBox>